# Application
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# Database (PostgreSQL)
DATABASE_URL=postgresql://rcar:rcar_secret@localhost:5432/rcar?schema=public

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis (used by BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage (MinIO / AWS S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=rcar-documents
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# PDF rendering (Puppeteer)
PDF_RENDER_TIMEOUT_MS=15000
# Optional path to Chromium/Chrome binary when Puppeteer bundled browser is unavailable.
PUPPETEER_EXECUTABLE_PATH=

# Email (SMTP) — set SMTP_USER/PASS for real delivery; leave blank for local Ethereal stub
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rcar.com.br

# Alerts — recipient for automated low-stock/reminder emails
ALERT_EMAIL=admin@rcar.com.br

# D4Sign (Digital Signature — Phase 6 production setup)
D4SIGN_TOKEN_API=
D4SIGN_CRYPT_KEY=
D4SIGN_SAFE_ID=
